  ;; ESP32 pin assignments (H1 2x19)
  ;; Pin 4 = GPIO4 → Q1 gate via R1
  (wire (pts (xy 4000 4850) (xy 6100 7650)))
  ;; Pin 19 = GPIO23 → Q2 gate via R2
  (wire (pts (xy 4000 4650) (xy 6100 6650)))
  ;; Pin 12 = GPIO12 → J4.3 Buzzer
  (wire (pts (xy 4000 5050) (xy 3500 5100)))
  (wire (pts (xy 3500 5100) (xy 3500 8400)))
  ;; Pin 13 = GPIO13 → J5.1 SW_LEFT
  (wire (pts (xy 4000 5150) (xy 5000 5150)))
  (wire (pts (xy 5000 5150) (xy 5000 8400)))
  ;; Pin 14 = GPIO14 → J5.2 SW_RIGHT
  (wire (pts (xy 4000 5250) (xy 5000 5250)))
  (wire (pts (xy 5000 5250) (xy 5000 8450)))
  ;; Pin 16 = GPIO16 → J3.5 RADAR_TX
  (wire (pts (xy 4000 5350) (xy 3000 5350)))
  (wire (pts (xy 3000 5350) (xy 3000 8420)))
  ;; Pin 17 = GPIO17 → J3.4 RADAR_RX
  (wire (pts (xy 4000 5450) (xy 3000 5450)))
  (wire (pts (xy 3000 5450) (xy 3000 8430)))
  ;; Pin 18 = GPIO18 → J6.2 C3_TX
  (wire (pts (xy 4000 5550) (xy 4500 5550)))
  (wire (pts (xy 4500 5550) (xy 4500 8420)))
  ;; Pin 19 = GPIO19 → J6.1 C3_RX
  (wire (pts (xy 4000 5650) (xy 4500 5650)))
  (wire (pts (xy 4500 5650) (xy 4500 8430)))
  ;; Pin 25 = GPIO25 → R5 → D1 LED_LEFT
  (wire (pts (xy 4000 5750) (xy 7600 5750)))
  (wire (pts (xy 7600 5750) (xy 7600 5500)))
  (wire (pts (xy 7600 5500) (xy 8000 5500)))
  ;; Pin 26 = GPIO26 → R6 → D2 LED_RIGHT
  (wire (pts (xy 4000 5850) (xy 7600 5850)))
  (wire (pts (xy 7600 5850) (xy 7600 4800)))
  (wire (pts (xy 7600 4800) (xy 8000 4800)))

  ;; MOSFET drains to turn lamp terminal
  (wire (pts (xy 6500 7500) (xy 7500 7500)))
  (wire (pts (xy 7500 7500) (xy 7500 7000)))
  (wire (pts (xy 6500 6500) (xy 7500 6500)))
  (wire (pts (xy 7500 6500) (xy 7500 6950)))

  ;; +12V to J7.3/J7.4
  (wire (pts (xy 2600 7000) (xy 7500 7100)))
  (wire (pts (xy 7500 7100) (xy 7500 6900)))

  ;; GND for LEDs
  (wire (pts (xy 8000 5600) (xy 8000 8700)))
  (wire (pts (xy 8000 4900) (xy 8000 8700)))

