    {"type":"rectangle","id":"leds","x":780,"y":30,"width":230,"height":300,"backgroundColor":"#1e3a5f","fillStyle":"solid","strokeColor":"#f59e0b","strokeWidth":2,"roundness":{"type":3},"boundElements":[{"id":"t_leds","type":"text"}]},
    {"type":"text","id":"t_leds","x":785,"y":40,"width":220,"height":20,"text":"2路 12V 转向灯 + MOSFET (V2.6 同侧前后并联)","fontSize":16,"fontFamily":1,"strokeColor":"#e5e5e5","textAlign":"center","verticalAlign":"middle","containerId":"leds","originalText":"2路 12V 转向灯 + MOSFET (V2.6 同侧前后并联)","autoResize":true},

    {"type":"text","id":"t_led_detail","x":790,"y":70,"text":"GPIO4→100Ω→IRLZ44N G  左侧(前+后并联)\n  12V→LED+  LED-→D  S→GND\n\nGPIO23→100Ω→IRLZ44N G  右侧(前+后并联)\n  12V→LED+  LED-→D  S→GND","fontSize":12,"fontFamily":1,"strokeColor":"#a0a0a0","originalText":"GPIO4→100Ω→IRLZ44N G  左侧(前+后并联)\n  12V→LED+  LED-→D  S→GND\n\nGPIO23→100Ω→IRLZ44N G  右侧(前+后并联)\n  12V→LED+  LED-→D  S→GND","autoResize":true},

    {"type":"rectangle","id":"indicators","x":780,"y":360,"width":230,"height":130,"backgroundColor":"#5c1a1a","fillStyle":"solid","strokeColor":"#ef4444","strokeWidth":2,"roundness":{"type":3},"boundElements":[{"id":"t_indicators","type":"text"}]},
    {"type":"text","id":"t_indicators","x":785,"y":370,"width":220,"height":20,"text":"RCW 指示灯 + 蜂鸣器","fontSize":16,"fontFamily":1,"strokeColor":"#e5e5e5","textAlign":"center","verticalAlign":"middle","containerId":"indicators","originalText":"RCW 指示灯 + 蜂鸣器","autoResize":true},
    {"type":"text","id":"t_ind_detail","x":790,"y":400,"text":"GPIO25→220Ω→LED左→GND\nGPIO26→220Ω→LED右→GND\nGPIO12→蜂鸣器I/O\n  5V→蜂鸣器VCC  GND→蜂鸣器GND","fontSize":12,"fontFamily":1,"strokeColor":"#a0a0a0","originalText":"GPIO25→220Ω→LED左→GND\nGPIO26→220Ω→LED右→GND\nGPIO12→蜂鸣器I/O\n  5V→蜂鸣器VCC  GND→蜂鸣器GND","autoResize":true},

    {"type":"rectangle","id":"switches","x":780,"y":510,"width":230,"height":100,"backgroundColor":"#1a4d4d","fillStyle":"solid","strokeColor":"#22c55e","strokeWidth":2,"roundness":{"type":3},"boundElements":[{"id":"t_switches","type":"text"}]},
    {"type":"text","id":"t_switches","x":785,"y":520,"width":220,"height":20,"text":"转向开关","fontSize":16,"fontFamily":1,"strokeColor":"#e5e5e5","textAlign":"center","verticalAlign":"middle","containerId":"switches","originalText":"转向开关","autoResize":true},
    {"type":"text","id":"t_sw_detail","x":790,"y":550,"text":"GPIO13─┤├─GND = 左转\nGPIO14─┤├─GND = 右转","fontSize":12,"fontFamily":1,"strokeColor":"#a0a0a0","originalText":"GPIO13─┤├─GND = 左转\nGPIO14─┤├─GND = 右转","autoResize":true},

