    {"type":"text","id":"bus5v","x":460,"y":200,"text":"5V 总线──→ ESP32 + 雷达 + 蜂鸣器VCC","fontSize":16,"fontFamily":1,"strokeColor":"#4a9eed","originalText":"5V 总线──→ ESP32 + 雷达 + 蜂鸣器VCC","autoResize":true},

    {"type":"rectangle","id":"esp32","x":30,"y":340,"width":250,"height":380,"backgroundColor":"#2d1b69","fillStyle":"solid","strokeColor":"#8b5cf6","strokeWidth":2,"roundness":{"type":3},"boundElements":[{"id":"t_esp32","type":"text"}]},
    {"type":"text","id":"t_esp32","x":35,"y":350,"width":240,"height":20,"text":"ESP32 DevKit","fontSize":18,"fontFamily":1,"strokeColor":"#e5e5e5","textAlign":"center","verticalAlign":"middle","containerId":"esp32","originalText":"ESP32 DevKit","autoResize":true},

    {"type":"text","id":"esp_pins","x":40,"y":380,"text":"GPIO16←雷达TX(⑤)   GPIO17→雷达RX(④)\nGPIO4→左侧灯(前后并联)  GPIO23→右侧灯(前后并联)\nGPIO25→左RCW LED   GPIO26→右RCW LED\nGPIO12→蜂鸣器       GPIO13←左转开关\nGPIO14←右转开关     GPIO27预留(V2.6移除双闪)","fontSize":14,"fontFamily":1,"strokeColor":"#a0a0a0","originalText":"GPIO16←雷达TX(⑤)   GPIO17→雷达RX(④)\nGPIO4→左侧灯(前后并联)  GPIO23→右侧灯(前后并联)\nGPIO25→左RCW LED   GPIO26→右RCW LED\nGPIO12→蜂鸣器       GPIO13←左转开关\nGPIO14←右转开关     GPIO27预留(V2.6移除双闪)","autoResize":true},

    {"type":"rectangle","id":"radar","x":500,"y":340,"width":220,"height":100,"backgroundColor":"#1a4d2e","fillStyle":"solid","strokeColor":"#22c55e","strokeWidth":2,"roundness":{"type":3},"boundElements":[{"id":"t_radar","type":"text"}]},
    {"type":"text","id":"t_radar","x":505,"y":355,"width":210,"height":40,"text":"MS60-3015 Radar\n5V|GND|OUT|RX|TX","fontSize":16,"fontFamily":1,"strokeColor":"#e5e5e5","textAlign":"center","verticalAlign":"middle","containerId":"radar","originalText":"MS60-3015 Radar\n5V|GND|OUT|RX|TX","autoResize":true},

    {"type":"arrow","id":"a_radar_rx","x":280,"y":410,"width":220,"height":0,"points":[[0,0],[220,0]],"endArrowhead":"arrow","strokeColor":"#22c55e","strokeWidth":1.5},
